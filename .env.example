# Sinopac brokerage / Shioaji API credentials.
# Optional: leave blank and the dashboard still works (PDF-only mode).
# When set, the post-PDF trade overlay (Phase 11+) backfills trades that
# happened after the most recent monthly statement closed.
#
# These are READ-ONLY in this app. The Shioaji client never imports order
# placement, modification, or CA-activation symbols. See app/shioaji_client.py.
SINOPAC_API_KEY=
SINOPAC_SECRET_KEY=

# Comma-separated PDF unlock candidates (existing pipeline; see scripts/decrypt_pdfs.py).
SINOPAC_PDF_PASSWORDS=

# Phase 9 startup behavior: when "true", boot kicks off backfill_runner in a
# background daemon thread. Disable in production or unit tests by leaving unset
# or setting to "false" — manual `python scripts/backfill_daily.py` still works.
BACKFILL_ON_STARTUP=false

# Optional admin-token gate on POST /api/admin/* (refresh, retry-failed,
# reconcile, dismiss). Off by default so the localhost workflow keeps
# working with no token. When set, every admin POST must echo the value
# via the X-Admin-Token request header — opt in only when exposing the
# dashboard via tunnel / LAN / reverse proxy. See app/__init__.py.
ADMIN_TOKEN=

# Override the default data/dashboard.db location. Useful in tests to swap
# in a per-test temporary SQLite file via tmp_path. Leave unset for normal
# use — the daily layer resolves the path relative to the repo root.
DAILY_DB_PATH=
